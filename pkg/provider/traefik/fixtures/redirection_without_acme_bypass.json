{
  "http": {
    "routers": {
      "acme-http": {
        "entryPoints": [
          "web"
        ],
        "service": "acme-http@internal",
        "rule": "PathPrefix(`/.well-known/acme-challenge/`)",
        "ruleSyntax": "default",
        "priority": 9223372036854775807
      },
      "web-to-websecure": {
        "entryPoints": [
          "web"
        ],
        "middlewares": [
          "redirect-web-to-websecure"
        ],
        "service": "noop@internal",
        "rule": "HostRegexp(`^.+$`)",
        "ruleSyntax": "default"
      }
    },
    "services": {
      "acme-http": {},
      "noop": {}
    },
    "middlewares": {
      "redirect-web-to-websecure": {
        "redirectScheme": {
          "scheme": "https",
          "port": "443",
          "permanent": true
        }
      }
    }
  },
  "tcp": {},
  "tls": {}
}